APP_NAME="FLCar"
APP_ENV=development
APP_META_DESCRIPTION="FLCar - Showroom o to cao cap. Xe nhap khau chinh hang, gia tot."
APP_HERO_TITLE="Premium Cars Collection"
APP_HERO_SUBTITLE="Dang cap - Chat luong - Gia tot nhat thi truong"

# Default profile: XAMPP
# For Docker profile, use .env.docker.example
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flcar_db
DB_USERNAME=root
DB_PASSWORD=

# Google Sign-In (set your OAuth Web client ID)
GOOGLE_CLIENT_ID=
